{
  "name": "vtex-checkout-kit",
  "private": false,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lint": "eslint --ext js,jsx,ts,tsx .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "dev": "eslint \"**/*.{ts,tsx}\" && vite build --watch",
    "build": "vite build",
    "clean": "rimraf checkout-ui-custom"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,js,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,graphql,gql}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jquery": "^3.5.33",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vtex/prettier-config": "0.1.4",
    "eslint": "^9.39.1",
    "husky": "4.2.3",
    "lint-staged": "10.1.1",
    "prettier": "2.0.2",
    "rimraf": "^6.0.1",
    "sass": "^1.93.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {}
}
